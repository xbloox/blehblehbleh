function Revival:CreateNotification(systemConfig)
	systemConfig = processConfig(systemConfig, {
		Position = "TopRight",
		Offset = Vector2.new(0, 0),
		DefaultDuration = 5,
		Padding = 10,
		MaxWidth = 400,
		MaxVisible = 5,
	})

	local notificationSystem = {
		Config = systemConfig,
		_LayoutCounter = 0,
		_VisibleQueue = {},
	}

	local container = Instance.new("Frame")
	container.Name = "RevivalNotifications"
	container.BackgroundTransparency = 1
	container.BorderSizePixel = 0
	container.AutomaticSize = Enum.AutomaticSize.XY
	container.Size = UDim2.new(0, 0, 0, 0)

	local preset = resolvePosition(systemConfig.Position, systemConfig.Offset)
	container.AnchorPoint = preset.AnchorPoint
	container.Position = preset.Position
	container.Parent = Revival.ScreenGui

	local layout = Instance.new("UIListLayout")
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, systemConfig.Padding)
	applyAlignmentForPreset(layout, preset)
	layout.Parent = container

	notificationSystem.Container = container
	notificationSystem.Layout = layout

	local function getStackOriginIsTop()
		return resolvePosition(notificationSystem.Config.Position).StackOrigin == "Top"
	end

	function notificationSystem.new(notifConfig)
		notifConfig = processConfig(notifConfig, {
			Title = "Notification",
			Content = "",
			Duration = systemConfig.DefaultDuration,
			Icon = nil,
			Logo = nil,
			AccentColor = nil,
		})

		local theme = Revival.Theme
		local accentColor = notifConfig.AccentColor or theme.AccentColor
		local currentPreset = resolvePosition(notificationSystem.Config.Position)

		notificationSystem._LayoutCounter += 1
		local layoutOrder = getStackOriginIsTop() and -notificationSystem._LayoutCounter or notificationSystem._LayoutCounter

		local notification = Instance.new("Frame")
		notification.BackgroundColor3 = theme.MainColor
		notification.BackgroundTransparency = 1
		notification.BorderSizePixel = 0
		notification.ClipsDescendants = true
		notification.LayoutOrder = layoutOrder

		local hasIcon = notifConfig.Icon ~= nil and notifConfig.Icon ~= ""
		local hasLogo = notifConfig.Logo ~= nil and notifConfig.Logo ~= ""
		local hasMedia = hasIcon or hasLogo
		local hasContent = notifConfig.Content ~= nil and notifConfig.Content ~= ""

		local mediaWidth = hasMedia and 45 or 0
		local leftPadding = hasMedia and 10 or 15
		local rightPadding = 15
		local mediaTextGap = hasMedia and 10 or 0
		local textOffsetX = leftPadding + mediaWidth + mediaTextGap

		local corner = Instance.new("UICorner")
		corner.CornerRadius = theme.CornerRadius
		corner.Parent = notification

		local stroke = Instance.new("UIStroke")
		stroke.Color = theme.BorderColor
		stroke.Transparency = 1
		stroke.Parent = notification

		local titleLabel = Instance.new("TextLabel")
		titleLabel.BackgroundTransparency = 1
		titleLabel.TextColor3 = theme.PrimaryTextColor
		titleLabel.TextSize = 16
		titleLabel.Font = theme.BoldFont
		titleLabel.Text = notifConfig.Title
		titleLabel.TextXAlignment = Enum.TextXAlignment.Left
		titleLabel.TextTransparency = 1
		titleLabel.Parent = notification

		local contentLabel
		if hasContent then
			contentLabel = Instance.new("TextLabel")
			contentLabel.BackgroundTransparency = 1
			contentLabel.TextColor3 = theme.PrimaryTextColor
			contentLabel.TextSize = 12
			contentLabel.Font = theme.Font
			contentLabel.Text = notifConfig.Content
			contentLabel.TextXAlignment = Enum.TextXAlignment.Left
			contentLabel.TextYAlignment = Enum.TextYAlignment.Top
			contentLabel.TextWrapped = true
			contentLabel.TextTransparency = 1
			contentLabel.Parent = notification
		end

		local titleSize = getTextSize(notifConfig.Title, 16, theme.BoldFont)
		local contentSize = hasContent and getTextSize(notifConfig.Content, 12, theme.Font) or Vector2.new(0, 0)

		local widestText = math.max(titleSize.X, contentSize.X)
		local desiredWidth = math.min(widestText + textOffsetX + rightPadding, systemConfig.MaxWidth)
		local minimumWidth = 180
		local finalWidth = math.max(desiredWidth, minimumWidth)

		local textAreaWidth = finalWidth - textOffsetX - rightPadding

		local contentWrapHeight = 0
		if hasContent then
			local wrapped = TextService:GetTextSize(
				notifConfig.Content,
				12,
				theme.Font,
				Vector2.new(textAreaWidth, math.huge)
			)
			contentWrapHeight = math.max(wrapped.Y, 15)
		end

		local titleHeight = 20
		local verticalPadding = 8
		local finalHeight
		if hasContent then
			finalHeight = verticalPadding * 2 + titleHeight + contentWrapHeight + 2
		else
			finalHeight = math.max(titleHeight + verticalPadding * 2, 45)
		end

		titleLabel.Position = UDim2.new(0, textOffsetX, 0, hasContent and verticalPadding or 0)
		titleLabel.Size = UDim2.new(0, textAreaWidth, 0, hasContent and titleHeight or finalHeight)
		if not hasContent then
			titleLabel.TextYAlignment = Enum.TextYAlignment.Center
		end

		if contentLabel then
			contentLabel.Position = UDim2.new(0, textOffsetX, 0, verticalPadding + titleHeight)
			contentLabel.Size = UDim2.new(0, textAreaWidth, 0, contentWrapHeight)
		end

		local mediaElementRef
		if hasMedia then
			if hasLogo then
				mediaElementRef = Instance.new("ImageLabel")
				mediaElementRef.BackgroundTransparency = 1
				mediaElementRef.Image = notifConfig.Logo
				mediaElementRef.ImageTransparency = 1
				mediaElementRef.ImageColor3 = theme.PrimaryTextColor

				local logoCorner = Instance.new("UICorner")
				logoCorner.CornerRadius = UDim.new(0, 7)
				logoCorner.Parent = mediaElementRef
			else
				mediaElementRef = Instance.new("TextLabel")
				mediaElementRef.BackgroundTransparency = 1
				mediaElementRef.TextColor3 = accentColor
				mediaElementRef.TextSize = 26
				mediaElementRef.TextTransparency = 1
				applyIcon(mediaElementRef, notifConfig.Icon)
			end

			mediaElementRef.AnchorPoint = Vector2.new(0, 0.5)
			mediaElementRef.Position = UDim2.new(0, leftPadding, 0.5, 0)
			mediaElementRef.Size = UDim2.new(0, 35, 0, 35)
			mediaElementRef.Parent = notification
		end

		notification.Size = UDim2.new(0, finalWidth, 0, finalHeight)

		notification.Parent = container

		local shadow = createShadow(notification, false)

		local slideOffset = 30
		local slideFrom = currentPreset.SlideFrom
		local startOffset = Vector2.new(0, 0)
		if slideFrom == "Right" then
			startOffset = Vector2.new(slideOffset, 0)
		elseif slideFrom == "Left" then
			startOffset = Vector2.new(-slideOffset, 0)
		elseif slideFrom == "Top" then
			startOffset = Vector2.new(0, -slideOffset)
		elseif slideFrom == "Bottom" then
			startOffset = Vector2.new(0, slideOffset)
		end

		notification.Position = UDim2.new(0, startOffset.X, 0, startOffset.Y)
		tween(notification, TWEEN_QUINT, {
			Position = UDim2.new(0, 0, 0, 0),
			BackgroundTransparency = theme.BackgroundTransparency,
		})
		tween(stroke, TWEEN_SLOW, { Transparency = theme.BorderTransparency })
		tween(titleLabel, TWEEN_SLOW, { TextTransparency = 0 })
		if contentLabel then
			tween(contentLabel, TWEEN_SLOW, { TextTransparency = 0.35 })
		end
		if mediaElementRef then
			if hasLogo then
				tween(mediaElementRef, TWEEN_SLOW, { ImageTransparency = 0 })
			else
				tween(mediaElementRef, TWEEN_SLOW, { TextTransparency = 0 })
			end
		end
		shadow:Render(true)

		local notificationHandle = {}
		notificationHandle.Root = notification

		local closeThread
		local closed = false

		local function close(fast)
			if closed then
				return
			end
			closed = true

			if closeThread and closeThread ~= coroutine.running() then
				pcall(task.cancel, closeThread)
			end
			closeThread = nil

			local exitTween = fast and TWEEN_FAST or TWEEN_SLOW
			local exitDelay = fast and 0.12 or 0.25
			local slideAmount = fast and 60 or math.max(notification.AbsoluteSize.X, notification.AbsoluteSize.Y) + 60

			local exitX, exitY = 0, 0
			if slideFrom == "Right" then
				exitX = slideAmount
			elseif slideFrom == "Left" then
				exitX = -slideAmount
			elseif slideFrom == "Top" then
				exitY = -slideAmount
			elseif slideFrom == "Bottom" then
				exitY = slideAmount
			end

			tween(notification, exitTween, {
				BackgroundTransparency = 1,
				Position = UDim2.new(0, exitX, 0, exitY),
			})
			tween(stroke, exitTween, { Transparency = 1 })
			tween(titleLabel, exitTween, { TextTransparency = 1 })
			if contentLabel then
				tween(contentLabel, exitTween, { TextTransparency = 1 })
			end
			if mediaElementRef then
				if hasLogo then
					tween(mediaElementRef, exitTween, { ImageTransparency = 1 })
				else
					tween(mediaElementRef, exitTween, { TextTransparency = 1 })
				end
			end
			shadow:Render(false)

			local queueIndex = table.find(notificationSystem._VisibleQueue, notificationHandle)
			if queueIndex then
				table.remove(notificationSystem._VisibleQueue, queueIndex)
			end

			task.delay(exitDelay, function()
				if notification.Parent then
					shadow:Destroy()
					notification:Destroy()
				end
			end)
		end

		notificationHandle.Close = close

		if notifConfig.Duration and notifConfig.Duration > 0 then
			closeThread = task.delay(notifConfig.Duration, close)
		end

		while #notificationSystem._VisibleQueue >= notificationSystem.Config.MaxVisible do
			local oldest = table.remove(notificationSystem._VisibleQueue, 1)
			if oldest and oldest.Close then
				oldest.Close(true)
			end
		end
		table.insert(notificationSystem._VisibleQueue, notificationHandle)

		return notificationHandle
	end

	function notificationSystem:SetPosition(newPosition)
		self.Config.Position = newPosition
		local newPreset = resolvePosition(newPosition, self.Config.Offset)
		container.AnchorPoint = newPreset.AnchorPoint
		container.Position = newPreset.Position
		applyAlignmentForPreset(layout, newPreset)
	end

	function notificationSystem:SetOffset(newOffset)
		self.Config.Offset = newOffset or Vector2.new(0, 0)
		local newPreset = resolvePosition(self.Config.Position, self.Config.Offset)
		container.AnchorPoint = newPreset.AnchorPoint
		container.Position = newPreset.Position
	end

	function notificationSystem:Clear()
		for index, child in container:GetChildren() do
			if child:IsA("Frame") then
				child:Destroy()
			end
		end
	end

	function notificationSystem:Destroy()
		container:Destroy()
		local componentIndex = table.find(Revival.Components, self)
		if componentIndex then
			table.remove(Revival.Components, componentIndex)
		end
	end

	table.insert(Revival.Components, notificationSystem)
	return notificationSystem
end

