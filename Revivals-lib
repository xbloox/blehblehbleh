function Revival:CreateTargetUI(systemConfig)
	systemConfig = processConfig(systemConfig, {
		Title = nil,
		Position = "MiddleLeft",
		Offset = Vector2.new(0, 0),
		CustomPosition = nil,
		AnchorPoint = nil,
		Width = 220,
		Draggable = true,
		AutoUpdate = true,
		HideWhenEmpty = false,
	})

	local theme = Revival.Theme

	local targetUI = {
		Config = systemConfig,
		Components = {},
		Visible = true,
		Paused = false,
	}

	local rootFrame = Instance.new("Frame")
	rootFrame.Name = "RevivalTargetUI"
	rootFrame.BackgroundColor3 = theme.MainColor
	rootFrame.BackgroundTransparency = theme.BackgroundTransparency
	rootFrame.BorderSizePixel = 0
	rootFrame.ClipsDescendants = true
	rootFrame.Size = UDim2.new(0, systemConfig.Width, 0, 40)

	local resolvedPreset = resolvePosition(systemConfig.Position, systemConfig.Offset)
	if systemConfig.CustomPosition then
		rootFrame.Position = systemConfig.CustomPosition
		rootFrame.AnchorPoint = systemConfig.AnchorPoint or Vector2.new(0, 0)
	else
		rootFrame.AnchorPoint = resolvedPreset.AnchorPoint
		rootFrame.Position = resolvedPreset.Position
	end
	rootFrame.Parent = Revival.ScreenGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = theme.CornerRadius
	corner.Parent = rootFrame

	local stroke = Instance.new("UIStroke")
	stroke.Color = theme.BorderColor
	stroke.Transparency = theme.BorderTransparency
	stroke.Parent = rootFrame

	local headerFrame
	local titleLabel
	local headerHeight = 0
	if systemConfig.Title then
		headerHeight = 30
		headerFrame = Instance.new("Frame")
		headerFrame.Name = "Header"
		headerFrame.BackgroundColor3 = theme.AccentColor
		headerFrame.BackgroundTransparency = 0.82
		headerFrame.BorderSizePixel = 0
		headerFrame.Size = UDim2.new(1, 0, 0, headerHeight)
		headerFrame.Position = UDim2.new(0, 0, 0, 0)
		headerFrame.Parent = rootFrame

		local headerTint = Instance.new("Frame")
		headerTint.Name = "HeaderTint"
		headerTint.BackgroundColor3 = theme.SecondaryColor
		headerTint.BackgroundTransparency = 0.4
		headerTint.BorderSizePixel = 0
		headerTint.Size = UDim2.new(1, 0, 1, 0)
		headerTint.Parent = headerFrame

		titleLabel = Instance.new("TextLabel")
		titleLabel.Name = "Title"
		titleLabel.BackgroundTransparency = 1
		titleLabel.Size = UDim2.new(1, 0, 1, 0)
		titleLabel.TextColor3 = theme.PrimaryTextColor
		titleLabel.TextSize = 13
		titleLabel.Font = theme.BoldFont
		titleLabel.Text = systemConfig.Title
		titleLabel.TextXAlignment = Enum.TextXAlignment.Center
		titleLabel.TextYAlignment = Enum.TextYAlignment.Center
		titleLabel.TextTransparency = 0.05
		titleLabel.ZIndex = 2
		titleLabel.Parent = headerFrame

		local headerBottomLine = Instance.new("Frame")
		headerBottomLine.Name = "HeaderBottomLine"
		headerBottomLine.AnchorPoint = Vector2.new(0, 1)
		headerBottomLine.BackgroundColor3 = theme.AccentColor
		headerBottomLine.BackgroundTransparency = 0.3
		headerBottomLine.BorderSizePixel = 0
		headerBottomLine.Position = UDim2.new(0, 0, 1, 0)
		headerBottomLine.Size = UDim2.new(1, 0, 0, 1)
		headerBottomLine.ZIndex = 3
		headerBottomLine.Parent = headerFrame
	end

	local contentArea = Instance.new("Frame")
	contentArea.Name = "Body"
	contentArea.BackgroundTransparency = 1
	contentArea.BorderSizePixel = 0
	contentArea.Position = UDim2.new(0, 0, 0, headerHeight)
	contentArea.Size = UDim2.new(1, 0, 1, -headerHeight)
	contentArea.Parent = rootFrame

	local contentLayout = Instance.new("UIListLayout")
	contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	contentLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	contentLayout.VerticalAlignment = Enum.VerticalAlignment.Top
	contentLayout.Padding = UDim.new(0, 6)
	contentLayout.Parent = contentArea

	local contentPadding = Instance.new("UIPadding")
	contentPadding.PaddingTop = UDim.new(0, 8)
	contentPadding.PaddingBottom = UDim.new(0, 8)
	contentPadding.PaddingLeft = UDim.new(0, 10)
	contentPadding.PaddingRight = UDim.new(0, 10)
	contentPadding.Parent = contentArea

	local shadow = createShadow(rootFrame, false)
	shadow:Render(true)

	if systemConfig.Draggable and headerFrame then
		makeDraggable(headerFrame, rootFrame, 0.1, true)
	elseif systemConfig.Draggable then
		makeDraggable(rootFrame, rootFrame, 0.1, true)
	end

	local componentLayoutCounter = 0

	local function resizeRoot()
		local contentSize = contentLayout.AbsoluteContentSize
		local verticalPadding = 16
		local finalHeight = contentSize.Y + verticalPadding + headerHeight
		tween(rootFrame, TWEEN_SLOW, { Size = UDim2.new(0, systemConfig.Width, 0, finalHeight) })
	end

	addConnection(contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(resizeRoot))

	local function setRootRender(visible)
		if visible then
			tween(rootFrame, TWEEN_SLOW, { BackgroundTransparency = theme.BackgroundTransparency })
			tween(stroke, TWEEN_SLOW, { Transparency = theme.BorderTransparency })
			if headerFrame then
				tween(headerFrame, TWEEN_SLOW, { BackgroundTransparency = 0.82 })
			end
			if titleLabel then
				tween(titleLabel, TWEEN_SLOW, { TextTransparency = 0.05 })
			end
			shadow:Render(true)
		else
			tween(rootFrame, TWEEN_SLOW, { BackgroundTransparency = 1 })
			tween(stroke, TWEEN_SLOW, { Transparency = 1 })
			if headerFrame then
				tween(headerFrame, TWEEN_SLOW, { BackgroundTransparency = 1 })
			end
			if titleLabel then
				tween(titleLabel, TWEEN_SLOW, { TextTransparency = 1 })
			end
			shadow:Render(false)
		end
	end

	local function buildBar(barConfig)
		barConfig = processConfig(barConfig, {
			Name = nil,
			Icon = nil,
			Color = theme.AccentColor,
			LerpSpeed = 8,
			ShowValue = true,
			ValueFormat = nil,
			GetValue = function()
				return 0, 100
			end,
			ResetOnNil = true,
		})

		componentLayoutCounter += 1

		local barComponent = {
			Type = "Bar",
			Config = barConfig,
			LayoutOrder = componentLayoutCounter,
			CurrentValue = 0,
			CurrentMax = 0,
			TargetValue = 0,
			TargetMax = 0,
			Visible = true,
		}

		local hasLabel = barConfig.Name ~= nil and barConfig.Name ~= ""

		local barFrame = Instance.new("Frame")
		barFrame.BackgroundTransparency = 1
		barFrame.BorderSizePixel = 0
		barFrame.LayoutOrder = componentLayoutCounter
		barFrame.Parent = contentArea

		local labelRowHeight = hasLabel and 16 or 0
		local barHeight = 10
		local fullHeight = labelRowHeight + barHeight + (hasLabel and 2 or 0)
		barFrame.Size = UDim2.new(1, 0, 0, fullHeight)

		local nameLabel
		local valueLabel

		if hasLabel then
			nameLabel = Instance.new("TextLabel")
			nameLabel.BackgroundTransparency = 1
			nameLabel.Position = UDim2.new(0, 0, 0, 0)
			nameLabel.Size = UDim2.new(0.5, 0, 0, labelRowHeight)
			nameLabel.TextColor3 = theme.PrimaryTextColor
			nameLabel.TextSize = 11
			nameLabel.Font = theme.BoldFont
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.TextTransparency = 0.2

			local iconLabel
			if barConfig.Icon then
				iconLabel = Instance.new("TextLabel")
				iconLabel.BackgroundTransparency = 1
				iconLabel.Position = UDim2.new(0, 0, 0, 0)
				iconLabel.Size = UDim2.new(0, 14, 0, labelRowHeight)
				iconLabel.TextColor3 = barConfig.Color
				iconLabel.TextSize = 13
				iconLabel.Parent = barFrame
				applyIcon(iconLabel, barConfig.Icon)

				nameLabel.Position = UDim2.new(0, 18, 0, 0)
				nameLabel.Size = UDim2.new(0.5, -18, 0, labelRowHeight)
			end

			nameLabel.Text = barConfig.Name
			nameLabel.Parent = barFrame

			valueLabel = Instance.new("TextLabel")
			valueLabel.BackgroundTransparency = 1
			valueLabel.AnchorPoint = Vector2.new(1, 0)
			valueLabel.Position = UDim2.new(1, 0, 0, 0)
			valueLabel.Size = UDim2.new(0.5, 0, 0, labelRowHeight)
			valueLabel.TextColor3 = theme.SecondaryTextColor
			valueLabel.TextSize = 11
			valueLabel.Font = theme.Font
			valueLabel.TextXAlignment = Enum.TextXAlignment.Right
			valueLabel.TextTransparency = 0.2
			valueLabel.Text = "0/0"
			valueLabel.Visible = barConfig.ShowValue
			valueLabel.Parent = barFrame
		end

		local barTrack = Instance.new("Frame")
		barTrack.BackgroundColor3 = theme.BarBackgroundColor
		barTrack.BackgroundTransparency = 0.2
		barTrack.BorderSizePixel = 0
		barTrack.Position = UDim2.new(0, 0, 0, labelRowHeight + (hasLabel and 2 or 0))
		barTrack.Size = UDim2.new(1, 0, 0, barHeight)
		barTrack.Parent = barFrame

		local trackCorner = Instance.new("UICorner")
		trackCorner.CornerRadius = UDim.new(1, 0)
		trackCorner.Parent = barTrack

		local barFill = Instance.new("Frame")
		barFill.BackgroundColor3 = barConfig.Color
		barFill.BorderSizePixel = 0
		barFill.Size = UDim2.new(0, 0, 1, 0)
		barFill.Parent = barTrack

		local fillCorner = Instance.new("UICorner")
		fillCorner.CornerRadius = UDim.new(1, 0)
		fillCorner.Parent = barFill

		barComponent._Frame = barFrame
		barComponent._BarFill = barFill
		barComponent._NameLabel = nameLabel
		barComponent._ValueLabel = valueLabel

		function barComponent:Update(deltaTime)
			local rawValue, rawMax = self.Config.GetValue()
			if rawValue == nil then
				if self.Visible then
					self._Frame.Visible = false
					self.Visible = false
				end
				if self.Config.ResetOnNil then
					self.CurrentValue = 0
					self.CurrentMax = 0
					self.TargetValue = 0
					self.TargetMax = 0
				end
				return
			end

			if not self.Visible then
				self._Frame.Visible = true
				self.Visible = true
			end

			self.TargetValue = tonumber(rawValue) or 0
			self.TargetMax = tonumber(rawMax) or self.TargetMax

			local alpha = 1 - math.exp(-self.Config.LerpSpeed * deltaTime)
			self.CurrentValue += (self.TargetValue - self.CurrentValue) * alpha
			self.CurrentMax += (self.TargetMax - self.CurrentMax) * alpha

			local effectiveMax = math.max(self.CurrentMax, 0.0001)
			local scale = self.CurrentMax <= 0 and 0 or math.clamp(self.CurrentValue / effectiveMax, 0, 1)
			self._BarFill.Size = UDim2.new(scale, 0, 1, 0)

			if self._ValueLabel and self.Config.ShowValue then
				if self.Config.ValueFormat then
					self._ValueLabel.Text = self.Config.ValueFormat(self.TargetValue, self.TargetMax)
				else
					self._ValueLabel.Text = string.format("%d/%d", math.floor(self.TargetValue + 0.5), math.floor(self.TargetMax + 0.5))
				end
			end
		end

		function barComponent:SetColor(color)
			self.Config.Color = color
			tween(self._BarFill, TWEEN_SLOW, { BackgroundColor3 = color })
		end

		function barComponent:SetName(name)
			self.Config.Name = name
			if self._NameLabel then
				self._NameLabel.Text = name
			end
		end

		function barComponent:SetVisible(visible)
			self.Visible = visible
			self._Frame.Visible = visible
		end

		function barComponent:Remove()
			self._Frame:Destroy()
			local componentIndex = table.find(targetUI.Components, self)
			if componentIndex then
				table.remove(targetUI.Components, componentIndex)
			end
		end

		table.insert(targetUI.Components, barComponent)
		return barComponent
	end

	local function buildLabel(labelConfig)
		labelConfig = processConfig(labelConfig, {
			Icon = nil,
			Color = theme.PrimaryTextColor,
			Align = "Center",
			TextSize = 13,
			Bold = true,
			GetValue = function()
				return ""
			end,
		})

		componentLayoutCounter += 1

		local labelComponent = {
			Type = "Label",
			Config = labelConfig,
			LayoutOrder = componentLayoutCounter,
			Visible = true,
		}

		local labelFrame = Instance.new("Frame")
		labelFrame.BackgroundTransparency = 1
		labelFrame.BorderSizePixel = 0
		labelFrame.LayoutOrder = componentLayoutCounter
		labelFrame.Size = UDim2.new(1, 0, 0, 18)
		labelFrame.Parent = contentArea

		local iconLabel
		local iconWidth = 0
		if labelConfig.Icon then
			iconWidth = 18
			iconLabel = Instance.new("TextLabel")
			iconLabel.BackgroundTransparency = 1
			iconLabel.AnchorPoint = Vector2.new(0, 0.5)
			iconLabel.Position = UDim2.new(0, 0, 0.5, 0)
			iconLabel.Size = UDim2.new(0, 16, 0, 16)
			iconLabel.TextColor3 = labelConfig.Color
			iconLabel.TextSize = 15
			iconLabel.Parent = labelFrame
			applyIcon(iconLabel, labelConfig.Icon)
		end

		local textLabel = Instance.new("TextLabel")
		textLabel.BackgroundTransparency = 1
		textLabel.Position = UDim2.new(0, iconWidth + (iconWidth > 0 and 4 or 0), 0, 0)
		textLabel.Size = UDim2.new(1, -(iconWidth + (iconWidth > 0 and 4 or 0)), 1, 0)
		textLabel.TextColor3 = labelConfig.Color
		textLabel.TextSize = labelConfig.TextSize
		textLabel.Font = labelConfig.Bold and theme.BoldFont or theme.Font
		textLabel.Text = ""
		textLabel.TextTransparency = 0.1
		textLabel.Parent = labelFrame

		if labelConfig.Align == "Left" then
			textLabel.TextXAlignment = Enum.TextXAlignment.Left
		elseif labelConfig.Align == "Right" then
			textLabel.TextXAlignment = Enum.TextXAlignment.Right
		else
			textLabel.TextXAlignment = Enum.TextXAlignment.Center
		end

		labelComponent._Frame = labelFrame
		labelComponent._TextLabel = textLabel
		labelComponent._IconLabel = iconLabel

		function labelComponent:Update(deltaTime)
			local value = self.Config.GetValue()
			if value == nil then
				if self.Visible then
					self._Frame.Visible = false
					self.Visible = false
				end
				return
			end

			if not self.Visible then
				self._Frame.Visible = true
				self.Visible = true
			end

			local text = tostring(value)
			if self._TextLabel.Text ~= text then
				self._TextLabel.Text = text
			end
		end

		function labelComponent:SetColor(color)
			self.Config.Color = color
			self._TextLabel.TextColor3 = color
			if self._IconLabel then
				self._IconLabel.TextColor3 = color
			end
		end

		function labelComponent:SetVisible(visible)
			self.Visible = visible
			self._Frame.Visible = visible
		end

		function labelComponent:Remove()
			self._Frame:Destroy()
			local componentIndex = table.find(targetUI.Components, self)
			if componentIndex then
				table.remove(targetUI.Components, componentIndex)
			end
		end

		table.insert(targetUI.Components, labelComponent)
		return labelComponent
	end

	local function buildFlag(flagConfig)
		flagConfig = processConfig(flagConfig, {
			Name = nil,
			GetValue = function()
				return nil
			end,
			DefaultColor = theme.FlagNeutralColor,
		})

		componentLayoutCounter += 1

		local flagComponent = {
			Type = "Flag",
			Config = flagConfig,
			LayoutOrder = componentLayoutCounter,
			Visible = true,
		}

		local hasName = flagConfig.Name ~= nil and flagConfig.Name ~= ""

		local flagFrame = Instance.new("Frame")
		flagFrame.BackgroundColor3 = theme.BarBackgroundColor
		flagFrame.BackgroundTransparency = 0.5
		flagFrame.BorderSizePixel = 0
		flagFrame.LayoutOrder = componentLayoutCounter
		flagFrame.Size = UDim2.new(1, 0, 0, 18)
		flagFrame.Parent = contentArea

		local flagCorner = Instance.new("UICorner")
		flagCorner.CornerRadius = UDim.new(0, 4)
		flagCorner.Parent = flagFrame

		local flagStroke = Instance.new("UIStroke")
		flagStroke.Color = theme.BorderColor
		flagStroke.Transparency = theme.BorderTransparency
		flagStroke.Parent = flagFrame

		local nameLabel
		if hasName then
			nameLabel = Instance.new("TextLabel")
			nameLabel.BackgroundTransparency = 1
			nameLabel.Position = UDim2.new(0, 6, 0, 0)
			nameLabel.Size = UDim2.new(0.5, 0, 1, 0)
			nameLabel.TextColor3 = theme.PrimaryTextColor
			nameLabel.TextSize = 11
			nameLabel.Font = theme.Font
			nameLabel.Text = flagConfig.Name
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.TextTransparency = 0.3
			nameLabel.Parent = flagFrame
		end

		local valueLabel = Instance.new("TextLabel")
		valueLabel.BackgroundTransparency = 1
		valueLabel.AnchorPoint = Vector2.new(1, 0)
		valueLabel.Position = UDim2.new(1, -6, 0, 0)
		valueLabel.Size = UDim2.new(hasName and 0.5 or 1, hasName and -6 or -12, 1, 0)
		valueLabel.TextColor3 = flagConfig.DefaultColor
		valueLabel.TextSize = 11
		valueLabel.Font = theme.BoldFont
		valueLabel.Text = ""
		valueLabel.TextXAlignment = hasName and Enum.TextXAlignment.Right or Enum.TextXAlignment.Center
		valueLabel.TextTransparency = 0
		valueLabel.Parent = flagFrame

		flagComponent._Frame = flagFrame
		flagComponent._ValueLabel = valueLabel
		flagComponent._NameLabel = nameLabel

		function flagComponent:Update(deltaTime)
			local text, color = self.Config.GetValue()
			if text == nil then
				if self.Visible then
					self._Frame.Visible = false
					self.Visible = false
				end
				return
			end

			if not self.Visible then
				self._Frame.Visible = true
				self.Visible = true
			end

			local newText = tostring(text)
			if self._ValueLabel.Text ~= newText then
				self._ValueLabel.Text = newText
			end

			if color and typeof(color) == "Color3" then
				self._ValueLabel.TextColor3 = color
			else
				self._ValueLabel.TextColor3 = self.Config.DefaultColor
			end
		end

		function flagComponent:SetName(name)
			self.Config.Name = name
			if self._NameLabel then
				self._NameLabel.Text = name
			end
		end

		function flagComponent:SetVisible(visible)
			self.Visible = visible
			self._Frame.Visible = visible
		end

		function flagComponent:Remove()
			self._Frame:Destroy()
			local componentIndex = table.find(targetUI.Components, self)
			if componentIndex then
				table.remove(targetUI.Components, componentIndex)
			end
		end

		table.insert(targetUI.Components, flagComponent)
		return flagComponent
	end

	local function buildSeparator()
		componentLayoutCounter += 1

		local separatorComponent = {
			Type = "Separator",
			LayoutOrder = componentLayoutCounter,
			Visible = true,
		}

		local separatorFrame = Instance.new("Frame")
		separatorFrame.BackgroundColor3 = theme.BorderColor
		separatorFrame.BackgroundTransparency = theme.BorderTransparency
		separatorFrame.BorderSizePixel = 0
		separatorFrame.LayoutOrder = componentLayoutCounter
		separatorFrame.Size = UDim2.new(1, -10, 0, 1)
		separatorFrame.Parent = contentArea

		separatorComponent._Frame = separatorFrame

		function separatorComponent:Update() end

		function separatorComponent:SetVisible(visible)
			self.Visible = visible
			self._Frame.Visible = visible
		end

		function separatorComponent:Remove()
			self._Frame:Destroy()
			local componentIndex = table.find(targetUI.Components, self)
			if componentIndex then
