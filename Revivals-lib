	function targetUI:AddBar(barConfig)
		return buildBar(barConfig)
	end

	function targetUI:AddLabel(labelConfig)
		return buildLabel(labelConfig)
	end

	function targetUI:AddFlag(flagConfig)
		return buildFlag(flagConfig)
	end

	function targetUI:AddSeparator()
		return buildSeparator()
	end

	function targetUI:SetTitle(text)
		if not titleLabel then
			return
		end
		titleLabel.Text = text or ""
	end

	function targetUI:SetVisible(visible)
		if self.Visible == visible then
			return
		end
		self.Visible = visible

		setRootRender(visible)

		for index, component in self.Components do
			local frame = component._Frame
			if not frame then
				continue
			end

			if visible then
				if component.Type == "Bar" then
					if component._NameLabel then
						tween(component._NameLabel, TWEEN_SLOW, { TextTransparency = 0.2 })
					end
					if component._ValueLabel then
						tween(component._ValueLabel, TWEEN_SLOW, { TextTransparency = 0.2 })
					end
				elseif component.Type == "Label" and component._TextLabel then
					tween(component._TextLabel, TWEEN_SLOW, { TextTransparency = 0.1 })
				elseif component.Type == "Flag" then
					if component._NameLabel then
						tween(component._NameLabel, TWEEN_SLOW, { TextTransparency = 0.3 })
					end
					if component._ValueLabel then
						tween(component._ValueLabel, TWEEN_SLOW, { TextTransparency = 0 })
					end
				end
			else
				if component.Type == "Bar" then
					if component._NameLabel then
						tween(component._NameLabel, TWEEN_SLOW, { TextTransparency = 1 })
					end
					if component._ValueLabel then
						tween(component._ValueLabel, TWEEN_SLOW, { TextTransparency = 1 })
					end
				elseif component.Type == "Label" and component._TextLabel then
					tween(component._TextLabel, TWEEN_SLOW, { TextTransparency = 1 })
				elseif component.Type == "Flag" then
					if component._NameLabel then
						tween(component._NameLabel, TWEEN_SLOW, { TextTransparency = 1 })
					end
					if component._ValueLabel then
						tween(component._ValueLabel, TWEEN_SLOW, { TextTransparency = 1 })
					end
				end
			end
		end
	end

	function targetUI:Pause()
		self.Paused = true
	end

	function targetUI:Resume()
		self.Paused = false
	end

	function targetUI:UpdateOnce()
		local deltaTime = 1 / 60
		for index, component in self.Components do
			if component.Update then
				component:Update(deltaTime)
			end
		end
	end

	function targetUI:SetPosition(newPosition)
		self.Config.Position = newPosition
		self.Config.CustomPosition = nil
		local newPreset = resolvePosition(newPosition, self.Config.Offset)
		rootFrame.AnchorPoint = newPreset.AnchorPoint
		rootFrame.Position = newPreset.Position
	end

	function targetUI:SetOffset(newOffset)
		self.Config.Offset = newOffset or Vector2.new(0, 0)
		if self.Config.CustomPosition then
			return
		end
		local newPreset = resolvePosition(self.Config.Position, self.Config.Offset)
		rootFrame.AnchorPoint = newPreset.AnchorPoint
		rootFrame.Position = newPreset.Position
	end

	function targetUI:SetCustomPosition(udim2, anchorPoint)
		self.Config.CustomPosition = udim2
		self.Config.AnchorPoint = anchorPoint
		rootFrame.AnchorPoint = anchorPoint or rootFrame.AnchorPoint
		rootFrame.Position = udim2
	end

	function targetUI:Destroy()
		if self._HeartbeatConnection then
			self._HeartbeatConnection:Disconnect()
			self._HeartbeatConnection = nil
		end
		shadow:Destroy()
		rootFrame:Destroy()
		table.clear(self.Components)
		local componentIndex = table.find(Revival.Components, self)
		if componentIndex then
			table.remove(Revival.Components, componentIndex)
		end
	end

	targetUI.Root = rootFrame

	if systemConfig.AutoUpdate then
		targetUI._HeartbeatConnection = addConnection(RunService.Heartbeat:Connect(function(deltaTime)
			if targetUI.Paused or not targetUI.Visible then
				return
			end

			for index, component in targetUI.Components do
				if component.Update then
					component:Update(deltaTime)
				end
			end

			if targetUI.Config.HideWhenEmpty then
				local anyVisible = false
				for index, component in targetUI.Components do
					if component.Visible then
						anyVisible = true
						break
					end
				end

				if anyVisible and rootFrame.BackgroundTransparency > 0.5 then
					setRootRender(true)
				elseif not anyVisible and rootFrame.BackgroundTransparency < 0.5 then
					setRootRender(false)
				end
			end
		end))
	end

	table.insert(Revival.Components, targetUI)
	return targetUI
end

-- ============================================================
-- UNLOAD
-- ============================================================

function Revival:Unload()
	if Revival._Unloaded then
		return
	end
	Revival._Unloaded = true

	for index, connection in Revival.Connections do
		pcall(function()
			connection:Disconnect()
		end)
	end
	table.clear(Revival.Connections)

	for index, component in Revival.Components do
		if component.Destroy then
			pcall(function()
				component:Destroy()
			end)
		end
	end
	table.clear(Revival.Components)

	if Revival.ScreenGui and Revival.ScreenGui.Parent then
		Revival.ScreenGui:Destroy()
	end
end

return Revival
