-- WATERMARK SYSTEM
-- ============================================================

function Revival:CreateWatermark(systemConfig)
	systemConfig = processConfig(systemConfig, {
		Position = "TopRight",
		Offset = Vector2.new(0, 0),
		CustomPosition = nil,
		AnchorPoint = nil,
		Orientation = "Horizontal",
		Draggable = false,
		Padding = 5,
	})

	local watermark = {
		Config = systemConfig,
		Blocks = {},
		Visible = true,
	}

	local theme = Revival.Theme

	local watermarkFrame = Instance.new("Frame")
	watermarkFrame.Name = "RevivalWatermark"
	watermarkFrame.BackgroundColor3 = theme.SecondaryColor
	watermarkFrame.BackgroundTransparency = 0.2
	watermarkFrame.BorderSizePixel = 0
	watermarkFrame.ClipsDescendants = true
	watermarkFrame.Size = UDim2.new(0, 30, 0, 30)
	watermarkFrame.AutomaticSize = Enum.AutomaticSize.None

	local watermarkPreset = resolvePosition(systemConfig.Position, systemConfig.Offset)
	if systemConfig.CustomPosition then
		watermarkFrame.Position = systemConfig.CustomPosition
		watermarkFrame.AnchorPoint = systemConfig.AnchorPoint or Vector2.new(0, 0)
	else
		watermarkFrame.AnchorPoint = watermarkPreset.AnchorPoint
		watermarkFrame.Position = watermarkPreset.Position
	end
	watermarkFrame.Parent = Revival.ScreenGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 25)
	corner.Parent = watermarkFrame

	local stroke = Instance.new("UIStroke")
	stroke.Color = theme.BorderColor
	stroke.Transparency = theme.BorderTransparency
	stroke.Parent = watermarkFrame

	local watermarkPadding = Instance.new("UIPadding")
	watermarkPadding.PaddingLeft = UDim.new(0, 10)
	watermarkPadding.PaddingRight = UDim.new(0, 10)
	watermarkPadding.PaddingTop = UDim.new(0, 5)
	watermarkPadding.PaddingBottom = UDim.new(0, 5)
	watermarkPadding.Parent = watermarkFrame

	local layout = Instance.new("UIListLayout")
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, systemConfig.Padding)
	if systemConfig.Orientation == "Vertical" then
		layout.FillDirection = Enum.FillDirection.Vertical
		layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	else
		layout.FillDirection = Enum.FillDirection.Horizontal
		layout.VerticalAlignment = Enum.VerticalAlignment.Center
	end
	layout.Parent = watermarkFrame

	local shadow = createShadow(watermarkFrame, false)
	shadow:Render(true)

	if systemConfig.Draggable then
		makeDraggable(watermarkFrame, watermarkFrame, 0.1, true)
	end

	local function recomputeSize()
		local contentSize = layout.AbsoluteContentSize
		local horizontalPad = 20
		local verticalPad = 10

		if systemConfig.Orientation == "Vertical" then
			tween(watermarkFrame, TWEEN_SLOW, {
				Size = UDim2.new(0, math.max(contentSize.X + horizontalPad, 50), 0, contentSize.Y + verticalPad),
			})
		else
			tween(watermarkFrame, TWEEN_SLOW, {
				Size = UDim2.new(0, contentSize.X + horizontalPad, 0, math.max(contentSize.Y + verticalPad, 30)),
			})
		end
	end

	addConnection(layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(recomputeSize))

	local blockOrderCounter = 0

	local function refreshDividers()
		local foundFirstVisible = false
		for index, block in watermark.Blocks do
			if block._Frame.Visible then
				if not foundFirstVisible then
					block._Divider.Visible = false
					foundFirstVisible = true
				else
					block._Divider.Visible = true
				end
			else
				block._Divider.Visible = false
			end
		end
	end

	function watermark:AddBlock(blockConfig)
		blockConfig = processConfig(blockConfig, {
			Icon = nil,
			Text = "",
			IconColor = nil,
			TextColor = nil,
		})

		local blockTheme = Revival.Theme
		local blockHandle = {}

		local hasIcon = blockConfig.Icon ~= nil and blockConfig.Icon ~= ""
		local iconColor = blockConfig.IconColor or blockTheme.AccentColor
		local textColor = blockConfig.TextColor or blockTheme.SecondaryTextColor

		local TEXT_SIZE = 14
		local ICON_BOX = 18
		local INNER_GAP = 6
		local SIDE_PAD = 6

		local function computeBlockWidth(textContent)
			local textBounds = getTextSize(tostring(textContent), TEXT_SIZE, blockTheme.BoldFont)
			if hasIcon then
				return SIDE_PAD + ICON_BOX + INNER_GAP + math.ceil(textBounds.X) + SIDE_PAD
			end
			return SIDE_PAD + math.ceil(textBounds.X) + SIDE_PAD
		end

		blockOrderCounter += 1

		local dividerFrame = Instance.new("Frame")
		dividerFrame.Name = "Divider"
		dividerFrame.BackgroundColor3 = blockTheme.BorderColor
		dividerFrame.BackgroundTransparency = 0.4
		dividerFrame.BorderSizePixel = 0
		dividerFrame.LayoutOrder = blockOrderCounter * 2 - 1
		if systemConfig.Orientation == "Vertical" then
			dividerFrame.Size = UDim2.new(0, 18, 0, 1)
		else
			dividerFrame.Size = UDim2.new(0, 1, 0, 16)
		end
		dividerFrame.Parent = watermarkFrame

		local blockFrame = Instance.new("Frame")
		blockFrame.Name = "Block"
		blockFrame.BackgroundTransparency = 1
		blockFrame.BorderSizePixel = 0
		blockFrame.Size = UDim2.new(0, computeBlockWidth(blockConfig.Text), 0, 30)
		blockFrame.LayoutOrder = blockOrderCounter * 2

		local iconLabel
		if hasIcon then
			iconLabel = Instance.new("TextLabel")
			iconLabel.BackgroundTransparency = 1
			iconLabel.AnchorPoint = Vector2.new(0, 0.5)
			iconLabel.Position = UDim2.new(0, SIDE_PAD, 0.5, 0)
			iconLabel.Size = UDim2.new(0, ICON_BOX, 0, ICON_BOX)
			iconLabel.TextColor3 = iconColor
			iconLabel.TextSize = 16
			iconLabel.TextTransparency = 0.2
			iconLabel.Parent = blockFrame
			applyIcon(iconLabel, blockConfig.Icon)
		end

		local textLabel = Instance.new("TextLabel")
		textLabel.BackgroundTransparency = 1
		textLabel.AnchorPoint = Vector2.new(0, 0.5)
		textLabel.Position = UDim2.new(0, hasIcon and (SIDE_PAD + ICON_BOX + INNER_GAP) or SIDE_PAD, 0.5, 0)
		textLabel.Size = UDim2.new(1, hasIcon and -(SIDE_PAD + ICON_BOX + INNER_GAP + SIDE_PAD) or -(SIDE_PAD + SIDE_PAD), 0, 18)
		textLabel.TextColor3 = textColor
		textLabel.TextSize = TEXT_SIZE
		textLabel.Font = blockTheme.BoldFont
		textLabel.Text = tostring(blockConfig.Text)
		textLabel.TextXAlignment = Enum.TextXAlignment.Left
		textLabel.TextYAlignment = Enum.TextYAlignment.Center
		textLabel.TextTransparency = 0.2
		textLabel.Parent = blockFrame

		blockFrame.Parent = watermarkFrame

		local clickButton = Instance.new("TextButton")
		clickButton.BackgroundTransparency = 1
		clickButton.Size = UDim2.new(1, 0, 1, 0)
		clickButton.Text = ""
		clickButton.AutoButtonColor = false
		clickButton.ZIndex = 2
		clickButton.Parent = blockFrame

		local function recomputeBlockSize(animated)
			local newWidth = computeBlockWidth(textLabel.Text)
			if animated then
				tween(blockFrame, TWEEN_SLOW, { Size = UDim2.new(0, newWidth, 0, 30) })
			else
				blockFrame.Size = UDim2.new(0, newWidth, 0, 30)
			end
		end

		function blockHandle:SetText(newText)
			textLabel.Text = tostring(newText)
			recomputeBlockSize(true)
		end

		function blockHandle:SetIcon(newIcon)
			if not iconLabel then
				return
			end
			applyIcon(iconLabel, newIcon)
		end

		function blockHandle:SetTextColor(color)
			textLabel.TextColor3 = color
		end

		function blockHandle:SetIconColor(color)
			if iconLabel then
				iconLabel.TextColor3 = color
			end
		end

		function blockHandle:SetVisible(visible)
			blockFrame.Visible = visible
			refreshDividers()
		end

		function blockHandle:OnClick(callback)
			return addConnection(clickButton.MouseButton1Click:Connect(callback))
		end

		function blockHandle:Remove()
			if blockFrame.Parent then
				blockFrame:Destroy()
			end
			if dividerFrame.Parent then
				dividerFrame:Destroy()
			end
			local blockIndex = table.find(watermark.Blocks, blockHandle)
			if blockIndex then
				table.remove(watermark.Blocks, blockIndex)
			end
			refreshDividers()
		end

		blockHandle._Frame = blockFrame
		blockHandle._Divider = dividerFrame
		blockHandle._TextLabel = textLabel
		blockHandle._IconLabel = iconLabel
		table.insert(watermark.Blocks, blockHandle)
		refreshDividers()

		return blockHandle
	end

	function watermark:SetVisible(visible)
		self.Visible = visible
		if visible then
			tween(watermarkFrame, TWEEN_SLOW, { BackgroundTransparency = 0.2 })
			tween(stroke, TWEEN_SLOW, { Transparency = theme.BorderTransparency })
			shadow:Render(true)
		else
			tween(watermarkFrame, TWEEN_SLOW, { BackgroundTransparency = 1 })
			tween(stroke, TWEEN_SLOW, { Transparency = 1 })
			shadow:Render(false)
		end

		for index, block in self.Blocks do
			if block._TextLabel then
				tween(block._TextLabel, TWEEN_SLOW, { TextTransparency = visible and 0.2 or 1 })
			end
			if block._IconLabel then
				tween(block._IconLabel, TWEEN_SLOW, { TextTransparency = visible and 0.25 or 1 })
			end
		end
	end

	function watermark:SetPosition(newPosition)
		self.Config.Position = newPosition
		self.Config.CustomPosition = nil
		local newPreset = resolvePosition(newPosition, self.Config.Offset)
		watermarkFrame.AnchorPoint = newPreset.AnchorPoint
		watermarkFrame.Position = newPreset.Position
	end

	function watermark:SetOffset(newOffset)
		self.Config.Offset = newOffset or Vector2.new(0, 0)
		if self.Config.CustomPosition then
			return
		end
		local newPreset = resolvePosition(self.Config.Position, self.Config.Offset)
		watermarkFrame.AnchorPoint = newPreset.AnchorPoint
		watermarkFrame.Position = newPreset.Position
	end

	function watermark:SetCustomPosition(udim2, anchorPoint)
		self.Config.CustomPosition = udim2
		self.Config.AnchorPoint = anchorPoint
		watermarkFrame.AnchorPoint = anchorPoint or watermarkFrame.AnchorPoint
		watermarkFrame.Position = udim2
	end

	function watermark:Destroy()
		shadow:Destroy()
		watermarkFrame:Destroy()
		local componentIndex = table.find(Revival.Components, self)
		if componentIndex then
			table.remove(Revival.Components, componentIndex)
		end
	end

	watermark.Root = watermarkFrame

	table.insert(Revival.Components, watermark)
	return watermark
end

