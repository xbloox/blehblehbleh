local function createScreenGui()
	local hostGui = (gethui and gethui())
		or cloneref(game:FindFirstChild("CoreGui"))
		or LocalPlayer:WaitForChild("PlayerGui")

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "RevivalUI_" .. tostring(math.random(100000, 999999))
	screenGui.IgnoreGuiInset = true
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
	screenGui.ResetOnSpawn = false
	screenGui.DisplayOrder = 999

	pcall(protectGui, screenGui)
	screenGui.Parent = hostGui

	return screenGui
end

Revival.ScreenGui = createScreenGui()

local function tween(instance, info, properties)
	if not instance or not instance.Parent then
		return nil
	end
	local tweenObject = TweenService:Create(instance, info or TWEEN_SLOW, properties)
	tweenObject:Play()
	return tweenObject
end

local function addConnection(connection)
	if not connection then
		return nil
	end
	table.insert(Revival.Connections, connection)
	return connection
end

local function processConfig(provided, defaults)
	local config = {}
	provided = provided or {}
	for key, value in defaults do
		if provided[key] ~= nil then
			config[key] = provided[key]
		else
			config[key] = value
		end
	end
	return config
end

local function getTextSize(text, size, font)
	return TextService:GetTextSize(
		text or "",
		size or 14,
		font or Revival.Theme.Font,
		Vector2.new(math.huge, math.huge)
	)
end

local function resolvePosition(positionInput, offsetVector)
	local basePreset
	if typeof(positionInput) == "string" and POSITION_PRESETS[positionInput] then
		basePreset = POSITION_PRESETS[positionInput]
	else
		basePreset = POSITION_PRESETS.TopRight
	end

	if offsetVector and (offsetVector.X ~= 0 or offsetVector.Y ~= 0) then
		local basePosition = basePreset.Position
		local offsetPosition = UDim2.new(
			basePosition.X.Scale,
			basePosition.X.Offset + offsetVector.X,
			basePosition.Y.Scale,
			basePosition.Y.Offset + offsetVector.Y
		)
		return {
			AnchorPoint = basePreset.AnchorPoint,
			Position = offsetPosition,
			StackOrigin = basePreset.StackOrigin,
			HorizontalAlignment = basePreset.HorizontalAlignment,
			VerticalAlignment = basePreset.VerticalAlignment,
			SlideFrom = basePreset.SlideFrom,
		}, false
	end

	return basePreset, false
end

local function applyIcon(label, iconString, useRegular)
	if not iconString or iconString == "" then
		label.Text = ""
		label.Visible = false
		return false
	end

	label.Visible = true

	local lowered = string.lower(iconString)
	local hasBoldSuffix = string.sub(lowered, -5) == "-bold"

	if hasBoldSuffix then
		label.Text = string.sub(iconString, 1, -6)
		label.FontFace = Revival.Theme.IconFont
	else
		label.Text = iconString
		label.FontFace = useRegular and Revival.Theme.IconFontRegular or Revival.Theme.IconFont
	end

	return true
end

local function createShadow(parent, doRolling)
	local strokes = {}
	local gradients = {}
	local thicknesses = { 6, 5, 4, 3 }

	for index, thickness in thicknesses do
		local stroke = Instance.new("UIStroke")
		stroke.Thickness = thickness
		stroke.Transparency = 1
		stroke.Color = Color3.fromRGB(0, 0, 0)
		stroke.Parent = parent

		if doRolling then
			local gradient = Instance.new("UIGradient")
			gradient.Transparency = NumberSequence.new({
				NumberSequenceKeypoint.new(0, 0.4),
				NumberSequenceKeypoint.new(1, 0),
			})
			gradient.Parent = stroke
			table.insert(gradients, gradient)
		end

		table.insert(strokes, stroke)
	end

	local rollingThread
	local shadow = {}

	function shadow:Render(visible)
		if rollingThread then
			task.cancel(rollingThread)
			rollingThread = nil
		end

		local targetTransparency = visible and 0.9 or 1
		for index, stroke in strokes do
			tween(stroke, TWEEN_SLOW, { Transparency = targetTransparency })
		end

		if visible and doRolling then
			rollingThread = task.spawn(function()
				while true do
					task.wait(0.025)
					local anyValid = false
					for index, gradient in gradients do
						if gradient.Parent then
							anyValid = true
							tween(gradient, TWEEN_SLOW, { Rotation = gradient.Rotation + 20 })
						end
					end
					if not anyValid then
						break
					end
				end
			end)
		end
	end

	function shadow:Destroy()
		if rollingThread then
			task.cancel(rollingThread)
			rollingThread = nil
		end
		for index, stroke in strokes do
			if stroke.Parent then
				stroke:Destroy()
			end
		end
		table.clear(strokes)
		table.clear(gradients)
	end

	return shadow
end

local function makeDraggable(handle, target, tweenSpeed, clampToParent)
	local isDragging = false
	local dragStart
	local startPos
	local dragTween = TweenInfo.new(tweenSpeed or 0.1)

	local function clampPosition(rawPosition)
		if not clampToParent then
			return rawPosition
		end
		local parent = target.Parent
		if not parent or not parent:IsA("GuiBase2d") then
			return rawPosition
		end

		local parentSize = parent.AbsoluteSize
		local frameSize = target.AbsoluteSize
		local anchor = target.AnchorPoint

		local pixelX = rawPosition.X.Scale * parentSize.X + rawPosition.X.Offset
		local pixelY = rawPosition.Y.Scale * parentSize.Y + rawPosition.Y.Offset

		local leftEdge = pixelX - frameSize.X * anchor.X
		local topEdge = pixelY - frameSize.Y * anchor.Y

		local maxLeft = math.max(0, parentSize.X - frameSize.X)
		local maxTop = math.max(0, parentSize.Y - frameSize.Y)

		leftEdge = math.clamp(leftEdge, 0, maxLeft)
		topEdge = math.clamp(topEdge, 0, maxTop)

		pixelX = leftEdge + frameSize.X * anchor.X
		pixelY = topEdge + frameSize.Y * anchor.Y

		return UDim2.new(0, pixelX, 0, pixelY)
	end

	addConnection(handle.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end

		isDragging = true
		dragStart = input.Position
		startPos = target.Position

		local endedConnection
		endedConnection = input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				isDragging = false
				if endedConnection then
					endedConnection:Disconnect()
				end
			end
		end)
	end))

	addConnection(UserInputService.InputChanged:Connect(function(input)
		if not isDragging then
			return
		end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
			return
		end

		local delta = input.Position - dragStart
		local newPosition = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
		tween(target, dragTween, { Position = clampPosition(newPosition) })
	end))
end

local function applyAlignmentForPreset(layout, preset)
	if not layout or not preset then
		return
	end
	layout.HorizontalAlignment = preset.HorizontalAlignment
	layout.VerticalAlignment = preset.VerticalAlignment
end

function Revival:SetTheme(themeOverrides)
	if not themeOverrides then
		return Revival.Theme
	end

	for key, value in themeOverrides do
		if Revival.Theme[key] ~= nil then
			Revival.Theme[key] = value
		end
	end

	for index, component in Revival.Components do
		if component.ApplyTheme then
			pcall(component.ApplyTheme, component)
		end
	end

	return Revival.Theme
end

function Revival:GetTheme()
	return Revival.Theme
end

