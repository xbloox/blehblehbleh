function Revival:CreateLogger(systemConfig)
	systemConfig = processConfig(systemConfig, {
		Position = "TopLeft",
		Offset = Vector2.new(0, 0),
		DefaultDuration = 3,
		Padding = 12,
		MaxWidth = 400,
		MaxVisible = 6,
	})

	local loggerSystem = {
		Config = systemConfig,
		_VisibleQueue = {},
	}

	local container = Instance.new("Frame")
	container.Name = "RevivalLogger"
	container.BackgroundTransparency = 1
	container.BorderSizePixel = 0
	container.AutomaticSize = Enum.AutomaticSize.XY
	container.Size = UDim2.new(0, 0, 0, 0)

	local preset = resolvePosition(systemConfig.Position, systemConfig.Offset)
	container.AnchorPoint = preset.AnchorPoint
	container.Position = preset.Position
	container.Parent = Revival.ScreenGui

	local layout = Instance.new("UIListLayout")
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, systemConfig.Padding)
	applyAlignmentForPreset(layout, preset)
	layout.Parent = container

	loggerSystem.Container = container
	loggerSystem.Layout = layout

	local logCounter = 0

	local function buildLog(icon, message, duration, accentColor)
		local theme = Revival.Theme
		duration = duration or systemConfig.DefaultDuration

		logCounter += 1
		local layoutOrder = resolvePosition(loggerSystem.Config.Position).StackOrigin == "Top" and -logCounter or logCounter

		local hasIcon = icon ~= nil and icon ~= ""
		local iconAreaWidth = hasIcon and 22 or 8
		local accent = accentColor or theme.AccentColor

		local logFrame = Instance.new("Frame")
		logFrame.BackgroundColor3 = theme.MainColor
		logFrame.BackgroundTransparency = 1
		logFrame.BorderSizePixel = 0
		logFrame.ClipsDescendants = true
		logFrame.LayoutOrder = layoutOrder
		logFrame.Size = UDim2.new(0, 0, 0, 20)

		local corner = Instance.new("UICorner")
		corner.CornerRadius = theme.SmallCornerRadius
		corner.Parent = logFrame

		local stroke = Instance.new("UIStroke")
		stroke.Color = theme.BorderColor
		stroke.Transparency = 1
		stroke.Parent = logFrame

		local accentLine = Instance.new("Frame")
		accentLine.AnchorPoint = Vector2.new(0, 0.5)
		accentLine.Position = UDim2.new(0, -2, 0.5, 0)
		accentLine.Size = UDim2.new(0, 5, 1, 0)
		accentLine.BackgroundColor3 = accent
		accentLine.BackgroundTransparency = 1
		accentLine.BorderSizePixel = 0
		accentLine.Parent = logFrame

		local accentCorner = Instance.new("UICorner")
		accentCorner.CornerRadius = theme.SmallCornerRadius
		accentCorner.Parent = accentLine

		local iconLabel
		if hasIcon then
			iconLabel = Instance.new("TextLabel")
			iconLabel.BackgroundTransparency = 1
			iconLabel.Position = UDim2.new(0, 7, 0.5, 0)
			iconLabel.AnchorPoint = Vector2.new(0, 0.5)
			iconLabel.Size = UDim2.new(0, 15, 0, 15)
			iconLabel.TextColor3 = theme.IconColor
			iconLabel.TextSize = 13
			iconLabel.TextTransparency = 1
			iconLabel.Parent = logFrame
			applyIcon(iconLabel, icon)
		end

		local messageLabel = Instance.new("TextLabel")
		messageLabel.BackgroundTransparency = 1
		messageLabel.Position = UDim2.new(0, hasIcon and iconAreaWidth + 4 or 10, 0, 0)
		messageLabel.AnchorPoint = Vector2.new(0, 0)
		messageLabel.TextColor3 = theme.PrimaryTextColor
		messageLabel.TextSize = 12
		messageLabel.Font = theme.BoldFont
		messageLabel.Text = tostring(message)
		messageLabel.TextXAlignment = Enum.TextXAlignment.Left
		messageLabel.TextYAlignment = Enum.TextYAlignment.Center
		messageLabel.TextTransparency = 1
		messageLabel.Parent = logFrame

		local textSize = getTextSize(tostring(message), 12, theme.BoldFont)
		local finalWidth = math.min(textSize.X + (hasIcon and iconAreaWidth + 8 or 18), systemConfig.MaxWidth)
		messageLabel.Size = UDim2.new(0, finalWidth - (hasIcon and iconAreaWidth + 4 or 10), 1, 0)

		logFrame.Parent = container

		local shadow = createShadow(logFrame, true)

		tween(logFrame, TWEEN_SLOW, {
			Size = UDim2.new(0, finalWidth, 0, 20),
			BackgroundTransparency = theme.BackgroundTransparency,
		})

		task.delay(0.1, function()
			tween(stroke, TWEEN_SLOW, { Transparency = theme.BorderTransparency })
			tween(accentLine, TWEEN_SLOW, { BackgroundTransparency = 0 })
			if iconLabel then
				tween(iconLabel, TWEEN_SLOW, { TextTransparency = 0.25 })
			end
			tween(messageLabel, TWEEN_SLOW, { TextTransparency = 0.25 })
			shadow:Render(true)
		end)

		local currentPreset = resolvePosition(loggerSystem.Config.Position)
		local logSlideFrom = currentPreset.SlideFrom

		local closeThread
		local closed = false
		local logHandle = { Root = logFrame }

		local function close(fast)
			if closed then
				return
			end
			closed = true

			if closeThread and closeThread ~= coroutine.running() then
				pcall(task.cancel, closeThread)
			end
			closeThread = nil

			local exitTween = fast and TWEEN_FAST or TWEEN_SLOW
			local exitDelay = fast and 0.12 or 0.25
			local slideAmount = fast and 60 or math.max(logFrame.AbsoluteSize.X, logFrame.AbsoluteSize.Y) + 60

			local exitX, exitY = 0, 0
			if logSlideFrom == "Right" then
				exitX = slideAmount
			elseif logSlideFrom == "Left" then
				exitX = -slideAmount
			elseif logSlideFrom == "Top" then
				exitY = -slideAmount
			elseif logSlideFrom == "Bottom" then
				exitY = slideAmount
			end

			tween(logFrame, exitTween, {
				BackgroundTransparency = 1,
				Position = UDim2.new(0, exitX, 0, exitY),
			})
			tween(stroke, exitTween, { Transparency = 1 })
			tween(accentLine, exitTween, { BackgroundTransparency = 1 })
			if iconLabel then
				tween(iconLabel, exitTween, { TextTransparency = 1 })
			end
			tween(messageLabel, exitTween, { TextTransparency = 1 })
			shadow:Render(false)

			local queueIndex = table.find(loggerSystem._VisibleQueue, logHandle)
			if queueIndex then
				table.remove(loggerSystem._VisibleQueue, queueIndex)
			end

			task.delay(exitDelay, function()
				if logFrame.Parent then
					shadow:Destroy()
					logFrame:Destroy()
				end
			end)
		end

		logHandle.Close = close

		if duration and duration > 0 then
			closeThread = task.delay(duration, close)
		end

		while #loggerSystem._VisibleQueue >= loggerSystem.Config.MaxVisible do
			local oldest = table.remove(loggerSystem._VisibleQueue, 1)
			if oldest and oldest.Close then
				oldest.Close(true)
			end
		end
		table.insert(loggerSystem._VisibleQueue, logHandle)

		return logHandle
	end

	function loggerSystem.new(...)
		local first = select(1, ...)

		if typeof(first) == "table" then
			local config = processConfig(first, {
				Icon = nil,
				Message = "",
				Duration = systemConfig.DefaultDuration,
				AccentColor = nil,
			})
			return buildLog(config.Icon, config.Message, config.Duration, config.AccentColor)
		end

		local icon, message, duration, accentColor = ...
		return buildLog(icon, message, duration, accentColor)
	end

	function loggerSystem:SetPosition(newPosition)
		self.Config.Position = newPosition
		local newPreset = resolvePosition(newPosition, self.Config.Offset)
		container.AnchorPoint = newPreset.AnchorPoint
		container.Position = newPreset.Position
		applyAlignmentForPreset(layout, newPreset)
	end

	function loggerSystem:SetOffset(newOffset)
		self.Config.Offset = newOffset or Vector2.new(0, 0)
		local newPreset = resolvePosition(self.Config.Position, self.Config.Offset)
		container.AnchorPoint = newPreset.AnchorPoint
		container.Position = newPreset.Position
	end

	function loggerSystem:Clear()
		for index, child in container:GetChildren() do
			if child:IsA("Frame") then
				child:Destroy()
			end
		end
	end

	function loggerSystem:Destroy()
		container:Destroy()
		local componentIndex = table.find(Revival.Components, self)
		if componentIndex then
			table.remove(Revival.Components, componentIndex)
		end
	end

	table.insert(Revival.Components, loggerSystem)
	return loggerSystem
end

